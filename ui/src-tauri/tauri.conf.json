{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PrivadoVPN",
  "version": "1.0.0",
  "identifier": "com.privadovpn.linux",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5188",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "PrivadoVPN",
        "width": 420,
        "height": 700,
        "minWidth": 380,
        "minHeight": 600,
        "maxWidth": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.privado.io https://*.privadovpn.com https://*.privado.live https://*.prvd.info https://f3556fm3o524m9.com https://3nkh5crxol.ch:15748 https://qya97ge69i2loo.com:7491 https://tsgqi2p2na3m7q.net:35486 https://monoprivacy.io:47654 https://netdefenderpro.com:14358 https://client-api.privado.live:59142 https://client-api.prvd.info:24865; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["strongswan", "strongswan-swanctl", "charon-systemd"],
        "section": "net",
        "priority": "optional"
      }
    },
    "category": "Utility"
  }
}
